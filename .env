
# Server Configuration
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=http://localhost:8080

# CORS Configuration - Permitir acesso do projeto Nutribox
CORS_ORIGIN=*
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# Logs - Apenas erros para produção local
LOG_LEVEL=ERROR,WARN,INFO
LOG_COLOR=true
LOG_BAILEYS=error

# Instance Management
DEL_INSTANCE=false
EVENT_EMITTER_MAX_LISTENERS=50

# Database Configuration - CONFIGURADO PARA SUPABASE
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://postgres.wubohcrfydjtzphnoyqu:[SUA_SENHA]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_CONNECTION_CLIENT_NAME=evolution_nutribox
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true
DATABASE_SAVE_IS_ON_WHATSAPP=true
DATABASE_DELETE_MESSAGE=false

# Message Storage - Banco de dados Supabase
STORE_MESSAGES=true
STORE_MESSAGE_UP=true
STORE_CONTACTS=true
STORE_CHATS=true

# External Services - Desabilitados
RABBITMQ_ENABLED=false
SQS_ENABLED=false
WEBSOCKET_ENABLED=false
PUSHER_ENABLED=false

# WhatsApp Business API
WA_BUSINESS_TOKEN_WEBHOOK=nutribox_webhook
WA_BUSINESS_URL=https://graph.facebook.com
WA_BUSINESS_VERSION=v20.0
WA_BUSINESS_LANGUAGE=pt_BR

# Webhook Configuration - Básico para testes
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=''
WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_SET=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_SEND_MESSAGE=true
WEBHOOK_EVENTS_CONTACTS_SET=true
WEBHOOK_EVENTS_CONTACTS_UPSERT=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true

# Session Configuration
CONFIG_SESSION_PHONE_CLIENT=Nutribox WhatsApp
CONFIG_SESSION_PHONE_NAME=Chrome
CONFIG_SESSION_PHONE_VERSION=2.3000.1015901307

# QR Code Configuration
QRCODE_LIMIT=30
QRCODE_COLOR=#22c55e

# Authentication - Chave para o projeto Nutribox
AUTHENTICATION_API_KEY=nutribox-evolution-key-2024
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
LANGUAGE=pt

# External Integrations - Desabilitados
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
DIFY_ENABLED=false

# Cache - Local apenas
CACHE_REDIS_ENABLED=false
CACHE_LOCAL_ENABLED=true

# Storage - Local
S3_ENABLED=false

# Sentry (opcional)
SENTRY_DSN=
